FROM qwen3.5:9b-q4_K_M

# Override the upstream Modelfile's aggressive defaults that combine badly
# with temperature=0 (greedy decoding) and trip 80K-token runaways:
#   presence_penalty 1.5  (Ollama's name for repeat penalty)
#   temperature 1
#   top_k 20
#   top_p 0.95
PARAMETER presence_penalty 0
PARAMETER temperature 0
PARAMETER top_k 0
PARAMETER top_p 1
